#DB
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

#PORT
PORT= 5000

JWT_SECRET=
JWTEXPIRY=15d

GMAIL_PASS=
GMAIL_USER=

# Optional: absolute path to PNG logo for email header (gear + SvayamExpense). If unset, uses backend/src/public/email/svayam-expense-logo.png when that file exists; otherwise an inline SVG header is used.
EMAIL_HEADER_LOGO_PATH=

GEMINI_API_KEY=

# Monthly cron (1st of month): 4 default categories; budget if missing = copy previous month else DEFAULT_CATEGORY_BUDGET_AMOUNT
CRON_DEFAULT_BUDGET_ENABLED=true
CRON_BUDGET_SCHEDULE=5 0 1 * *
CRON_TIMEZONE=Asia/Kolkata
DEFAULT_CATEGORY_BUDGET_AMOUNT=5000
# Other categories: admin POST /api/admin/budget (dropdown) or CategoryBudget; edit defaults via PUT /api/admin/budget/:id
# On month rollover: delete all user_monthly_budgets for that month (category_only for everyone)
CRON_CLEAR_USER_BUDGETS=true
# Optional: POST /api/internal/cron/rollover-default-budgets with header X-Cron-Secret
CRON_MANUAL_SECRET=

 